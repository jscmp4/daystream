# DayStream 配置
# 复制这个文件为 .env，然后填入你的实际值
# cp .env.example .env

# ===== 服务器 =====
PORT=3100
HOST=localhost

# ===== 数据存储 =====
# SQLite 数据库路径
DB_PATH=./data/daystream.db
# 原始文件存储路径
RAW_FILES_PATH=./data/raw

# ===== screenpipe =====
SCREENPIPE_API_URL=http://localhost:3030

# ===== AI 服务（按需填写）=====
# OpenAI（用于 Whisper 转录和 embedding）
OPENAI_API_KEY=

# Google Gemini（用于多模态理解）
GEMINI_API_KEY=

# ===== Omi 设备（未来）=====
# OMI_API_URL=
